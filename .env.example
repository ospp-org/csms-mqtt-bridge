# ─── Required ───────────────────────────────────────────────────────────────

# MQTT broker URL (full URL incl. protocol).
MQTT_BROKER_URL=mqtts://mqtt-uat.onestoppay.ro:8884

# MQTT clientid for this sidecar; must match the CN of the server certificate
# (per OSPP spec — EMQX uses peer_cert_as_clientid = cn).
MQTT_CLIENT_ID=csms-uat-server-1

# Server certificate (PEM), signed by the Station CA.
MQTT_CERT_PATH=/run/secrets/server-cert.pem

# Server private key (PEM, mode 0600). NOT logged anywhere.
MQTT_KEY_PATH=/run/secrets/server-key.pem

# CA chain presented in TLS handshake (Station CA + Root CA).
MQTT_CA_PATH=/run/secrets/server-chain.pem

# Redis URL (full URL incl. protocol). The csms-server compose runs Redis with
# --requirepass, so production URLs include the password as the userinfo
# component. Format: redis://[username][:password]@host:port[/db].
# Use rediss:// for TLS-wrapped Redis.
REDIS_URL=redis://:<password>@csms-redis:6379/0

# ─── Optional (defaults shown) ──────────────────────────────────────────────

# Optional: TLS SNI hostname override (sent to broker during TLS handshake).
# Set when the broker certificate SAN doesn't include the connect hostname.
# Example: connecting intra-Docker to 'emqx' but the broker cert covers
# '*.onestoppay.ro' — set MQTT_SERVERNAME=mqtt-uat.onestoppay.ro.
# When unset, defaults to the host portion of MQTT_BROKER_URL.
# MQTT_SERVERNAME=

# Validate the broker certificate against MQTT_CA_PATH? Default: true.
# DO NOT set to false outside of an ephemeral sandbox — it disables peer
# verification entirely.
# MQTT_REJECT_UNAUTHORIZED=true

# Pino log level: trace | debug | info | warn | error | fatal.
# LOG_LEVEL=info

# Prometheus exporter port (1..65535).
# METRICS_PORT=9090

# Graceful shutdown deadline, in milliseconds.
# SHUTDOWN_TIMEOUT_MS=10000

# MQTT keepalive interval, in seconds.
# MQTT_KEEPALIVE=60

# MQTT reconnect base period, in milliseconds.
# (mqtt.js applies exponential backoff with jitter on top.)
# MQTT_RECONNECT_PERIOD=5000

# MQTT initial connect timeout, in milliseconds.
# MQTT_CONNECT_TIMEOUT=30000

# Redis list keys for the bridge queues.
# REDIS_QUEUE_INCOMING=mqtt:incoming
# REDIS_QUEUE_OUTGOING=mqtt:outgoing
# REDIS_QUEUE_PROCESSING=mqtt:processing

# BLMOVE block timeout when polling the outgoing queue, in seconds.
# (Same name kept for backwards compat; covers BLMOVE since 0.5.)
# REDIS_BLPOP_TIMEOUT_SEC=5
